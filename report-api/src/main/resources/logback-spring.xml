<configuration>
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <customFields>{"service":"report-api"}</customFields>
            <providers>

                <timestamp />
                <logLevel />
                <loggerName />
                <threadName />

                <message />

                <mdc />

                <stackTrace />
            </providers>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="JSON" />
    </root>
</configuration>